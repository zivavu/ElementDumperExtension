{
	"manifest_version": 2,
	"default_locale": "en",
	"name": "__MSG_extensionName__",
	"version": "0.0.3",
	"description": "__MSG_extensionDescription__",
	"permissions": ["activeTab", "clipboardWrite", "storage"],
	"icons": {
		"256": "icons/icon.png"
	},
	"browser_action": {
		"default_title": "__MSG_actionDefaultTitle__",
		"default_icon": {
			"256": "icons/icon.png"
		}
	},
	"background": {
		"scripts": ["background.js"]
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"],
			"run_at": "document_idle",
			"all_frames": true
		}
	],
	"commands": {
		"toggle-dumper": {
			"suggested_key": {
				"default": "Alt+Shift+D"
			},
			"description": "__MSG_commandToggleDumper__"
		}
	},
	"data_collection_permissions": [],
	"browser_specific_settings": {
		"gecko": {
			"id": "element-dumper@example.com"
		}
	}
}
