{
	"manifest_version": 2,
	"name": "Element Dumper",
	"version": "0.0.3",
	"description": "Hover over any page element, navigate its DOM ancestors, and copy its HTML (with inlined styles or raw classes) to clipboard.",
	"permissions": ["activeTab", "clipboardWrite"],
	"browser_action": {
		"default_title": "Toggle Element Dumper (Alt+Shift+D)",
		"default_icon": "icons/icon.png"
	},
	"background": {
		"scripts": ["background.js"]
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"],
			"run_at": "document_idle"
		}
	],
	"commands": {
		"toggle-dumper": {
			"suggested_key": {
				"default": "Alt+Shift+D"
			},
			"description": "Toggle Element Dumper on/off"
		}
	},
	"browser_specific_settings": {
		"gecko": {
			"id": "element-dumper@example.com"
		}
	}
}
